@startuml
title LeninKart Platform Architecture

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Segoe UI
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 12
}
skinparam package {
  BorderColor #4b5563
}
skinparam ArrowColor #334155
skinparam ArrowThickness 1.2

legend right
  Current validated scope:
  - Jira-driven deployment request
  - GitHub Actions on self-hosted runner
  - GitOps via leninkart-infra/dev
  - ArgoCD on k3d-leninkart-dev
  - frontend, product-service, order-service
  - project-validation browser proof
endlegend

package "Request & Control" as control {
  actor "Operator" as operator
  rectangle "Jira Ticket\nSCRUM-* deployment request" as jira
  rectangle "GitHub Actions\nworkflow_dispatch\nDeploy From Jira" as gha
  rectangle "Self-hosted Runner\nleninkart-runner\nWindows / local / dev" as runner
}

package "Orchestration & Safety" as orchestration {
  rectangle "deployment-poc\norchestrator" as poc
  rectangle "Config Mapping\nprojects / apps /\nenvironments / jira fields" as config
  rectangle "Safety Layer\nstate + locks + stale-lock recovery\n+ idempotency + rollback scaffolding" as safety
  rectangle "Jira Feedback\nprogress comments\n+ final transitions/comments" as feedback
}

package "GitOps & Delivery" as delivery {
  rectangle "leninkart-infra\nbranch: dev" as infra
  rectangle "ArgoCD\nleninkart-root + child apps" as argocd
  rectangle "Exact Revision Verification\nSync = Synced\nHealth = Healthy" as verify
}

package "Runtime Services\nk3d-leninkart-dev" as runtime {
  rectangle "frontend-dev" as frontend
  rectangle "dev-product-service" as product
  rectangle "dev-order-service" as order
  rectangle "Platform Runtime\npostgres / ingress / vault /\nexternal-secrets / loadtest" as support
}

package "Platform Support" as platform {
  rectangle "kafka-platform\nexternal Kafka runtime" as kafka
  rectangle "observability-stack\nbootstrap + generated values" as obsboot
  rectangle "Observability Runtime\nGrafana / Prometheus /\nLoki / Promtail / Tempo" as obsrt
}

package "Validation & Proof" as proof {
  rectangle "project-validation" as pv
  rectangle "Real UI Proof\nGitHub / GitOps / ArgoCD /\nApp / Observability screenshots" as ui
  rectangle "Reports & Docs\nMkDocs / evidence index /\nvalidation reports" as docs
}

operator --> jira
jira --> gha : ticket key used as input
gha --> runner
runner --> poc
poc --> config
poc --> safety
poc --> feedback
poc --> infra : update values-dev.yaml\ncommit + push
infra --> argocd : GitOps source of truth
argocd --> verify
argocd --> frontend
argocd --> product
argocd --> order
argocd --> support
frontend --> kafka
product --> kafka
order --> kafka
obsboot --> infra : generates observability values
argocd --> obsrt
pv --> gha : public run UI proof
pv --> infra : GitOps commit proof
pv --> argocd : sync/health proof
pv --> frontend : application proof
pv --> obsrt : dashboard/log/trace proof
pv --> ui
pv --> docs

@enduml
