@startuml
title LeninKart Platform Architecture
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Segoe UI
skinparam packageStyle rectangle
skinparam rectangle { RoundCorner 12 }
skinparam package { BorderColor #475569; FontStyle bold }
skinparam ArrowColor #334155
skinparam ArrowThickness 1.4
skinparam linetype ortho
legend right
  Verified current model:
  - ArgoCD runs inside the k3d Kubernetes cluster
  - App workloads, platform support, and observability runtime are in-cluster
  - Kafka runs outside Kubernetes via Docker Compose
  - observability-stack/bootstrap is outside the cluster
  - deployment-poc runs in the self-hosted runner path
  - project-validation is observer-only
endlegend
package "External Control & Source Repos" as external {
  actor "Operator" as operator
  rectangle "Jira Cloud\nmanual deployment request" as jira
  rectangle "GitHub Actions\nworkflow_dispatch" as gha
  rectangle "leninkart-infra\nGitOps repo / dev branch" as infra
}
package "Local Execution & Bootstrap" as exec {
  rectangle "Self-hosted Runner\nWindows / local / dev" as runner
  rectangle "deployment-poc\norchestrator + safety layer" as poc
  rectangle "observability-stack/bootstrap\ngenerates observability values" as obsboot
}
package "Local Docker Host" as host {
  package "k3d-leninkart-dev Kubernetes Cluster" as cluster {
    rectangle "ArgoCD\nargocd namespace" as argocd
    rectangle "Application Workloads\nfrontend\nproduct-service\norder-service" as apps
    rectangle "Platform Support\ningress\nPostgres\nVault\nExternal Secrets\nloadtest" as support
    rectangle "Observability Runtime\nGrafana\nPrometheus\nLoki\nPromtail\nTempo" as obs
  }
  package "Docker Compose Runtime" as compose {
    rectangle "Kafka\nkafka-platform" as kafka
  }
}
package "Validation & Proof (observer only)" as proof {
  rectangle "project-validation" as pv
  rectangle "Browser UI Proof\nGitHub / GitOps / ArgoCD / app / observability" as ui
  rectangle "Reports & Evidence\nMkDocs / screenshots / docs" as docs
}
operator --> jira
operator --> gha : dispatch with jira key
gha --> runner
runner --> poc
poc --> jira : read + comment
poc --> infra : push desired state
obsboot --> infra : write observability values
infra --> argocd : desired revision
argocd --> apps : reconcile
apps --> support : cluster services
apps --> kafka : events
apps ..> obs : telemetry
kafka ..> obs : metrics
pv ..> gha : CI proof
pv ..> infra : GitOps proof
pv ..> argocd : sync / health proof
pv ..> apps : app proof
pv ..> obs : observability proof
pv --> ui
pv --> docs
@enduml
