@startuml
title LeninKart Platform Architecture

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Segoe UI
skinparam packageStyle rectangle
skinparam rectangle { RoundCorner 12 }
skinparam package { BorderColor #4b5563 }
skinparam ArrowColor #334155
skinparam ArrowThickness 1.2
skinparam linetype ortho

legend right
  Corrected architecture facts:
  - ArgoCD runs inside the k3d Kubernetes cluster
  - Kafka runs outside Kubernetes via Docker Compose
  - observability-stack bootstrap runs outside the cluster
  - observability runtime runs inside the cluster
  - project-validation is observer-only
endlegend

package "External Control & Source Repos" as external {
  actor "Operator" as operator
  rectangle "Jira Cloud
manual deployment request" as jira
  rectangle "GitHub Actions
workflow_dispatch
Deploy From Jira" as gha
  rectangle "GitHub Repo
leninkart-infra / dev" as infra
}

package "Local Execution & Bootstrap
(same laptop as runner + k3d)" as execution {
  rectangle "Self-hosted Runner
Windows / local / dev" as runner
  rectangle "deployment-poc
orchestrator + safety layer" as poc
  rectangle "observability-stack
bootstrap generator" as obsboot
}

package "Local Docker Host" as dockerhost {
  package "k3d-leninkart-dev
Kubernetes Cluster" as cluster {
    rectangle "ArgoCD Control Plane
argocd namespace" as argocd
    rectangle "Application Workloads
frontend + product-service + order-service
via ingress in dev" as apps
    rectangle "In-cluster Platform Support
Postgres + Vault + External Secrets
+ ingress + loadtest" as support
    rectangle "In-cluster Observability Runtime
Grafana + Prometheus + Loki + Promtail + Tempo" as obsrt
  }
  package "Docker Compose Runtime" as compose {
    rectangle "kafka-platform
external runtime for cluster workloads" as kafka
  }
}

package "Validation & Proof
(observer only)" as proof {
  rectangle "project-validation" as pv
  rectangle "Browser UI proof
GitHub + GitOps + ArgoCD + app + observability" as ui
  rectangle "Reports & Docs
MkDocs + screenshots + evidence" as docs
}

operator --> jira : create / update ticket
operator --> gha : workflow_dispatch(jira_ticket)
gha --> runner : schedule deploy job
runner --> poc : execute orchestration
poc --> jira : read metadata
write progress / final feedback
poc --> infra : commit + push
desired state
obsboot --> infra : generate observability values
infra --> argocd : GitOps desired state
poc --> argocd : exact revision
sync / health checks
argocd --> apps : reconcile
argocd --> support : reconcile
argocd --> obsrt : reconcile
apps --> kafka : runtime messaging
apps --> support : database, secrets, ingress
apps ..> obsrt : metrics / logs / traces
kafka ..> obsrt : scrape metrics

pv ..> gha : run UI proof
pv ..> infra : commit proof
pv ..> argocd : sync / health proof
pv ..> apps : application proof
pv ..> obsrt : dashboard / log / trace proof
pv --> ui
pv --> docs

@enduml
