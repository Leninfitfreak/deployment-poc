@startuml
title LeninKart Detailed Platform Architecture
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Segoe UI
skinparam packageStyle rectangle
skinparam rectangle { RoundCorner 12 }
skinparam package { BorderColor #475569; FontStyle bold }
skinparam ArrowColor #334155
skinparam ArrowThickness 1.2
skinparam linetype ortho

package "External Control & Source Repos" as external {
  actor Operator
  rectangle "Jira Cloud" as jira
  rectangle "GitHub Actions" as gha
  rectangle "leninkart-infra\nGitOps repo / dev" as infra
}

package "Local Execution & Bootstrap" as exec {
  rectangle "Self-hosted Runner" as runner
  rectangle "deployment-poc" as poc
  rectangle "observability-stack/bootstrap" as obsboot
}

package "Validation & Proof\n(observer only)" as proof {
  rectangle "project-validation" as pv
  rectangle "Browser UI proof" as uiproof
  rectangle "Reports / screenshots / evidence" as evid
}

package "Local Docker Host" as host {
  package "k3d-leninkart-dev Kubernetes Cluster" as cluster {
    rectangle "ArgoCD" as argocd
    package "Application Workloads" as apps {
      rectangle "frontend" as frontend
      rectangle "product-service" as product
      rectangle "order-service" as order
    }
    package "Platform Support" as support {
      rectangle "ingress-nginx" as ingress
      rectangle "postgres" as postgres
      rectangle "vault" as vault
      rectangle "external-secrets" as extsec
      rectangle "traffic-generator" as loadtest
    }
    package "Observability Runtime" as obs {
      rectangle "Grafana" as grafana
      rectangle "Prometheus" as prom
      rectangle "Loki" as loki
      rectangle "Promtail" as promtail
      rectangle "Tempo" as tempo
    }
  }
  package "Docker Compose Runtime" as compose {
    rectangle "Kafka\n(single-node KRaft broker)" as kafka
  }
}

Operator --> jira
Operator --> gha
gha --> runner
runner --> poc
poc --> jira : read + comment
poc --> infra : push desired state
obsboot --> infra : write values
infra --> argocd : desired revision
argocd --> apps : reconcile apps
apps --> support : cluster services
apps --> kafka : events
apps ..> obs : telemetry
kafka ..> prom : metrics
pv ..> gha : CI proof
pv ..> infra : GitOps proof
pv ..> argocd : ArgoCD proof
pv ..> apps : app proof
pv ..> obs : observability proof
pv --> uiproof
pv --> evid
@enduml
