@startuml
title LeninKart Platform Architecture (Showcase)
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Segoe UI
skinparam packageStyle rectangle
skinparam rectangle { RoundCorner 14 }
skinparam package { BorderColor #475569; FontStyle bold }
skinparam ArrowColor #334155
skinparam ArrowThickness 1.4
skinparam linetype ortho
package "Request & Control" as request {
  actor Operator
  rectangle "Jira Cloud" as jira
  rectangle "GitHub Actions" as gha
}
package "Execution & Orchestration" as exec {
  rectangle "Self-hosted Runner" as runner
  rectangle "deployment-poc" as poc
  rectangle "Jira feedback" as jirafb
}
package "GitOps & Delivery" as delivery {
  rectangle "leninkart-infra" as infra
  rectangle "ArgoCD" as argocd
}
package "Runtime Platform" as runtime {
  package "k3d-leninkart-dev Kubernetes Cluster" as cluster {
    rectangle "Application Workloads" as apps
    rectangle "Platform Support" as support
    rectangle "Observability Runtime" as obs
  }
  package "Docker Compose Runtime" as compose {
    rectangle "Kafka\nkafka-platform" as kafka
  }
}
package "Validation & Proof (observer only)" as proof {
  rectangle "project-validation" as pv
  rectangle "Browser UI proof" as ui
  rectangle "Reports & evidence" as docs
}
Operator --> jira
Operator --> gha
gha --> runner
runner --> poc
poc --> infra
poc --> jirafb
jirafb --> jira
infra --> argocd
argocd --> apps
apps --> support
apps --> kafka
apps ..> obs
kafka ..> obs
pv ..> gha : CI proof
pv ..> argocd : control-plane proof
pv ..> runtime : runtime proof
pv --> ui
pv --> docs
@enduml
